{
  "name": "treadline",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "build:wasm": "cd treadline-wasm && wasm-pack build --target web --out-dir ../src/ai/wasm-pkg",
    "build:cards": "cd scripts/card-gen && source .venv/bin/activate && python3 render_cards.py --placeholder && cp -r output/* ../../public/cards/",
    "copy:cards": "cp -r scripts/card-gen/output/* public/cards/",
    "bench": "vitest bench",
    "benchmark": "vitest bench",
    "profile": "samply record cargo run --release --manifest-path treadline-runner/Cargo.toml -- --games 1 --iterations 20 --threads 1",
    "prepare": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "next": "^16.1.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
